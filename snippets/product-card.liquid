{% doc %}
  Renders a product card (image with hover swap, optional New / Sale badges,
  title, short descriptor, price in ink, and an eco/origin micro-line).
  Reused by featured products and collection grids.

  @param {object} card_product - The product to render
  @param {string} [sizes] - The responsive `sizes` attribute (default 25vw desktop)

  @example
  {% render 'product-card', card_product: product %}
{% enddoc %}

{% liquid
  assign now_s = 'now' | date: '%s' | plus: 0
  assign created_s = card_product.created_at | date: '%s' | plus: 0
  assign age = now_s | minus: created_s
  assign is_new = false
  if age < 2592000
    assign is_new = true
  endif
  assign on_sale = false
  if card_product.compare_at_price > card_product.price
    assign on_sale = true
  endif
  assign card_desc = card_product.metafields.custom.short_description
%}

<a class="card" href="{{ card_product.url }}">
  <div class="card__media">
    {% if card_product.featured_media %}
      {{
        card_product.featured_media.preview_image
        | image_url: width: 800
        | image_tag:
          widths: '300, 400, 600, 800',
          sizes: sizes | default: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
          loading: 'lazy',
          class: 'card__image',
          alt: card_product.featured_media.preview_image.alt | default: card_product.title
      }}
      {% if card_product.media[1] %}
        {{
          card_product.media[1].preview_image
          | image_url: width: 800
          | image_tag:
            widths: '300, 400, 600, 800',
            sizes: sizes | default: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
            loading: 'lazy',
            class: 'card__image card__image--hover',
            alt: ''
        }}
      {% endif %}
    {% endif %}

    {% if is_new or on_sale %}
      <div class="card__badges">
        {% if on_sale %}
          <span class="card__badge card__badge--sale">{{ 'product.sale' | t }}</span>
        {% elsif is_new %}
          <span class="card__badge card__badge--new">{{ 'product.new' | t }}</span>
        {% endif %}
      </div>
    {% endif %}
  </div>

  <div class="card__info">
    <h3 class="card__title">{{ card_product.title }}</h3>
    {% if card_desc != blank %}
      <p class="card__desc">{{ card_desc | strip_html | truncate: 72 }}</p>
    {% endif %}
    <div class="card__price">
      {% if card_product.price_varies %}
        <span class="card__price-current">
          {{ 'product.from_price_html' | t: price: card_product.price_min | money }}
        </span>
      {% else %}
        <span class="card__price-current">{{ card_product.price | money }}</span>
      {% endif %}
      {% if on_sale %}
        <s class="card__price-compare">{{ card_product.compare_at_price | money }}</s>
      {% endif %}
    </div>
  </div>
</a>

{% stylesheet %}
  .card {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .card__media {
    position: relative;
    aspect-ratio: 4 / 5;
    margin-bottom: 0.85rem;
    border-radius: var(--rar-radius-card);
    overflow: hidden;
    background-color: var(--rar-color-surface);
  }
  .card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .card__image--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  .card:hover .card__image--hover {
    opacity: 1;
  }
  .card:hover .card__image:not(.card__image--hover) {
    transform: scale(1.03);
  }
  .card__badges {
    position: absolute;
    inset-block-start: 0.75rem;
    inset-inline-start: 0.75rem;
    display: flex;
    gap: 0.4rem;
  }
  .card__badge {
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #fff;
  }
  .card__badge--sale {
    background-color: var(--rar-promo);
  }
  .card__badge--new {
    background-color: var(--rar-color-ink);
  }
  .card__title {
    margin: 0 0 0.2rem;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .card__desc {
    margin: 0 0 0.4rem;
    color: rgb(28 40 48 / 55%);
    font-size: 0.8125rem;
    line-height: 1.4;
  }
  .card__price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--rar-price);
    font-weight: 600;
  }
  .card__price-compare {
    color: rgb(28 40 48 / 45%);
    font-weight: 400;
  }
{% endstylesheet %}
