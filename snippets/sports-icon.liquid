{% doc %}
  Renders the brand sport picto (SVG in /assets) chosen from a collection handle
  keyword. Falls back to a generic mark when no keyword matches.

  @param {string} handle - The collection handle (e.g. "surfboard-wall-mount")

  @example
  {% render 'sports-icon', handle: collection.handle %}
{% enddoc %}

{% liquid
  assign h = handle | downcase
  assign icon = ''
  if h contains 'kite' or h contains 'wake'
    assign icon = 'cat-kite-surf.svg'
  elsif h contains 'surf'
    assign icon = 'cat-surf.svg'
  elsif h contains 'skate'
    assign icon = 'cat-skate.svg'
  elsif h contains 'snow'
    assign icon = 'cat-snowboard.svg'
  elsif h contains 'ski'
    assign icon = 'cat-skis.svg'
  elsif h contains 'bike' or h contains 'velo'
    assign icon = 'cat-bike.svg'
  elsif h contains 'deco'
    assign icon = 'cat-deco.svg'
  endif
%}
{%- if icon != blank -%}
  {{ icon | inline_asset_content }}
{%- else -%}
  <svg viewBox="0 0 48 48" width="48" height="48" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="16"/><path d="M24 8v32M8 24h32"/></svg>
{%- endif -%}
