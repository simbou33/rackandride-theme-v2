{% doc %}
  Renders a line-style sport icon chosen from a collection handle keyword.
  Falls back to a generic mark when no keyword matches.

  @param {string} handle - The collection handle (e.g. "surfboard-wall-mount")

  @example
  {% render 'sports-icon', handle: collection.handle %}
{% enddoc %}

{% liquid
  assign h = handle | downcase
%}
{%- if h contains 'surf' -%}
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M7 25C3 13 13 3 25 7c4 12-6 22-18 18z" stroke-linejoin="round"/><path d="M11 21l10-10" stroke-linecap="round"/></svg>
{%- elsif h contains 'skate' -%}
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 13h22a2 2 0 0 1 0 4H5a2 2 0 0 1 0-4z" stroke-linejoin="round"/><circle cx="10" cy="22" r="2.4"/><circle cx="22" cy="22" r="2.4"/></svg>
{%- elsif h contains 'snow' -%}
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="13" y="3" width="6" height="26" rx="3"/><path d="M16 9v14" stroke-linecap="round"/></svg>
{%- elsif h contains 'ski' -%}
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M12 4v22c0 1.5-3 1.5-3 0V4z"/><path d="M23 4v22c0 1.5-3 1.5-3 0V4z"/></svg>
{%- elsif h contains 'bike' or h contains 'velo' -%}
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="8" cy="22" r="5"/><circle cx="24" cy="22" r="5"/><path d="M8 22l5-10h7l4 10M13 12h6" stroke-linecap="round" stroke-linejoin="round"/></svg>
{%- elsif h contains 'kite' or h contains 'wake' -%}
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M16 3l11 9-11 5L5 12z"/><path d="M16 17v7m-3 4h6" stroke-linecap="round"/></svg>
{%- elsif h contains 'deco' -%}
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 28c0-7 0-11 0-14"/><path d="M16 14c-2-5-6-6-9-5 0 5 4 7 9 5z"/><path d="M16 16c2-6 6-7 10-6 0 6-5 8-10 6z"/></svg>
{%- else -%}
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="16" cy="16" r="11"/><path d="M16 5v22M5 16h22" stroke-linecap="round"/></svg>
{%- endif -%}
