{% comment %}
  Global footer. Block-based so merchants can compose columns: menu lists, a
  brand/eco text block, and a newsletter sign-up. A bottom bar carries the
  copyright and (optionally) the store's payment icons. All UI strings come
  from translation keys; block content is merchant-editable and localizable.
{% endcomment %}

<footer class="footer full-width">
  <div class="footer__inner">
    <div class="footer__brand">
      {% render 'logo', variant: 'wordmark', class: 'footer__logo', size: 28 %}
      {% if section.settings.tagline != blank %}
        <p class="footer__tagline">{{ section.settings.tagline }}</p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="footer__columns">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'menu' %}
              <div class="footer__column" {{ block.shopify_attributes }}>
                {% if block.settings.heading != blank %}
                  <h2 class="footer__heading">{{ block.settings.heading }}</h2>
                {% endif %}
                {% if block.settings.menu != blank %}
                  <ul class="footer__menu" role="list">
                    {% for link in block.settings.menu.links %}
                      <li>
                        <a class="footer__link" href="{{ link.url }}">{{ link.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>

            {% when 'text' %}
              <div class="footer__column" {{ block.shopify_attributes }}>
                {% if block.settings.heading != blank %}
                  <h2 class="footer__heading">{{ block.settings.heading }}</h2>
                {% endif %}
                <div class="footer__text rte">{{ block.settings.content }}</div>
              </div>

            {% when 'newsletter' %}
              <div class="footer__column footer__column--newsletter" {{ block.shopify_attributes }}>
                {% if block.settings.heading != blank %}
                  <h2 class="footer__heading">{{ block.settings.heading }}</h2>
                {% endif %}
                {% if block.settings.text != blank %}
                  <div class="footer__text rte">{{ block.settings.text }}</div>
                {% endif %}
                {% form 'customer', class: 'footer__newsletter' %}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  {% if form.posted_successfully? %}
                    <p class="footer__newsletter-success">{{ 'newsletter.success' | t }}</p>
                  {% else %}
                    <div class="footer__newsletter-field">
                      <label class="visually-hidden" for="NewsletterEmail-{{ block.id }}">
                        {{ 'newsletter.email_label' | t }}
                      </label>
                      <input
                        id="NewsletterEmail-{{ block.id }}"
                        type="email"
                        name="contact[email]"
                        class="footer__newsletter-input"
                        placeholder="{{ 'newsletter.email_label' | t }}"
                        autocomplete="email"
                        required
                      >
                      <button type="submit" class="footer__newsletter-button">
                        {{ 'newsletter.button' | t }}
                      </button>
                    </div>
                  {% endif %}
                {% endform %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="footer__bottom">
    {% if shop.policies.size > 0 %}
      <ul class="footer__policies" role="list">
        {% for policy in shop.policies %}
          {% if policy.url != blank %}
            <li><a class="footer__policy-link" href="{{ policy.url }}">{{ policy.title }}</a></li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}

    <div class="footer__bottom-inner">
      <div class="footer__locale">
        {% render 'language-selector', id_prefix: 'ftr' %}
      </div>

      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
      </p>

      {% if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 %}
        <ul class="footer__payment" role="list">
          {% for type in shop.enabled_payment_types %}
            <li>{{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    margin-top: 4rem;
    background-color: var(--rar-color-surface);
    color: var(--rar-text);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: 3rem;
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 4rem var(--rar-page-margin) 2.5rem;
  }
  .footer__brandname {
    margin: 0.85rem 0 0;
    font-family: var(--rar-font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .footer__tagline {
    max-width: 32ch;
    margin-top: 1.25rem;
    color: rgb(28 40 48 / 70%);
    font-size: 0.9375rem;
  }

  .footer__columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 2.5rem;
  }
  .footer__heading {
    margin: 0 0 1rem;
    font-size: 1rem;
    font-weight: 600;
  }
  .footer__menu {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .footer__link {
    color: rgb(28 40 48 / 75%);
    font-size: 0.9375rem;
    text-decoration: none;
  }
  .footer__link:hover {
    color: var(--rar-accent);
  }
  .footer__text {
    color: rgb(28 40 48 / 75%);
    font-size: 0.9375rem;
  }

  .footer__newsletter-field {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .footer__newsletter-input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 0.65rem 0.85rem;
    border: 1px solid rgb(28 40 48 / 20%);
    border-radius: var(--rar-radius-button);
    background-color: var(--rar-color-background);
    color: var(--rar-text);
  }
  .footer__newsletter-button {
    flex: 0 0 auto;
    padding: 0.65rem 1.25rem;
    border: 0;
    border-radius: var(--rar-radius-button);
    background-color: var(--rar-accent);
    color: #fff;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }
  .footer__newsletter-button:hover {
    filter: brightness(0.94);
  }
  .footer__newsletter-success {
    margin-top: 1rem;
    color: var(--rar-eco);
    font-weight: 600;
  }

  .footer__bottom {
    border-top: 1px solid rgb(28 40 48 / 10%);
  }
  .footer__policies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 1.25rem var(--rar-page-margin) 0;
    list-style: none;
  }
  .footer__policy-link {
    color: rgb(28 40 48 / 60%);
    font-size: 0.8125rem;
    text-decoration: none;
  }
  .footer__policy-link:hover {
    color: var(--rar-accent);
  }
  .footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 1.25rem var(--rar-page-margin);
  }
  .footer__copyright {
    margin: 0;
    color: rgb(28 40 48 / 60%);
    font-size: 0.8125rem;
  }
  .footer__payment {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .footer__payment-icon {
    width: 2.25rem;
    height: auto;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (max-width: 749px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding-top: 3rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "textarea",
      "id": "tagline",
      "label": "t:labels.tagline",
      "default": "Handmade wall mounts in solid oak — crafted in Gironde, France. Beeswax & linseed finish, cork pads, recyclable packaging."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "t:general.footer_menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:labels.menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:general.text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:labels.text"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:general.newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading",
          "default": "Newsletter"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:labels.text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.footer",
      "blocks": [
        { "type": "menu" },
        { "type": "menu" },
        { "type": "newsletter" }
      ]
    }
  ]
}
{% endschema %}
