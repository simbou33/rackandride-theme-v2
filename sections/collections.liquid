{% comment %}
  List-collections page (/collections): a grid of all collections as cards
  (collection image, or first product image as fallback) linking to each.
{% endcomment %}

<section class="collections-list">
  <header class="collections-list__header">
    <h1 class="collections-list__title">{{ 'collections.title' | t }}</h1>
  </header>

  <div class="collections-list__grid">
    {% for collection in collections %}
      {% liquid
        assign tile_image = collection.image
        unless tile_image
          assign tile_image = collection.products.first.featured_media.preview_image
        endunless
      %}
      <a class="collection-card" href="{{ collection.url }}">
        <div class="collection-card__media">
          {% if tile_image %}
            {{
              tile_image
              | image_url: width: 800
              | image_tag:
                widths: '300, 400, 600, 800',
                sizes: '(min-width: 750px) 33vw, 50vw',
                loading: 'lazy',
                alt: collection.title
            }}
          {% endif %}
        </div>
        <span class="collection-card__label">
          {{ collection.title }}
          <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true" focusable="false"><path d="M5 10h10M11 6l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .collections-list {
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 2.5rem var(--rar-page-margin) 4rem;
  }
  .collections-list__header {
    margin-bottom: 2.5rem;
    text-align: center;
  }
  .collections-list__title {
    margin: 0;
    font-size: clamp(1.85rem, 1.2rem + 2.4vw, 3rem);
  }
  .collections-list__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .collection-card {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .collection-card__media {
    aspect-ratio: 3 / 4;
    margin-bottom: 0.75rem;
    border-radius: var(--rar-radius-card);
    overflow: hidden;
    background-color: var(--rar-color-surface);
  }
  .collection-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .collection-card:hover .collection-card__media img {
    transform: scale(1.04);
  }
  .collection-card__label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--rar-font-heading);
    font-size: 1.0625rem;
    font-weight: 600;
  }
  .collection-card__label svg {
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    color: var(--rar-accent);
  }
  .collection-card:hover .collection-card__label svg {
    opacity: 1;
    transform: translateX(2px);
  }
  @media (min-width: 750px) {
    .collections-list__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collections_grid",
  "settings": []
}
{% endschema %}
