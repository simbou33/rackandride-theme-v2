{% comment %}
  Featured products: a heading + a responsive grid of product cards from a
  chosen collection, with an optional "View all" link. Renders nothing if no
  collection is set.
{% endcomment %}

{% liquid
  assign collection = section.settings.collection
  assign limit = section.settings.products_to_show
%}

{% if collection != blank and collection.products.size > 0 %}
  <section class="featured">
    <div class="featured__header">
      {% if section.settings.heading != blank %}
        <h2 class="featured__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.show_view_all %}
        <a class="featured__view-all" href="{{ collection.url }}">
          {{ 'general.view_all' | t }}
          <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true" focusable="false"><path d="M5 10h10M11 6l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {% endif %}
    </div>

    <div class="featured__grid">
      {% for product in collection.products limit: limit %}
        {% render 'product-card', card_product: product %}
      {% endfor %}
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .featured {
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 4rem var(--rar-page-margin);
  }
  .featured__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .featured__title {
    margin: 0;
    font-size: clamp(1.75rem, 1.2rem + 2vw, 2.5rem);
  }
  .featured__view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex: 0 0 auto;
    color: var(--rar-accent);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }
  .featured__view-all:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .featured__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (min-width: 750px) {
    .featured__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.75rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.featured_products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Featured"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:general.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:labels.products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:labels.show_view_all",
      "default": true
    }
  ],
  "presets": [{ "name": "t:general.featured_products" }],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
