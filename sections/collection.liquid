{% comment %}
  Collection page (SEO-first, modern layout). Centered header, a sport-icon
  category switcher, a horizontal filter bar (dropdown facets) + sort, a
  full-width product grid, a bottom rich-text SEO block and an editable FAQ.

  Per-collection content is read from metafields (translatable via Translate &
  Adapt), with graceful fallbacks:
  - intro → custom.seo_intro (fallback: collection.description)
  - body  → custom.seo_body
  - faq   → custom.faq  (JSON: [{ "question": "...", "answer": "..." }])
{% endcomment %}

{% liquid
  assign intro = collection.metafields.custom.seo_intro
  if intro == blank
    assign intro = collection.description
  endif
  assign faq = collection.metafields.custom.faq.value
  assign sort_by = collection.sort_by | default: collection.default_sort_by
%}

<div class="collection" data-section-id="{{ section.id }}">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol class="breadcrumbs__list">
      <li class="breadcrumbs__item">
        <a href="{{ routes.root_url }}">{{ 'general.home' | t }}</a>
      </li>
      <li class="breadcrumbs__item" aria-current="page">{{ collection.title }}</li>
    </ol>
  </nav>

  <header class="collection__header">
    <h1 class="collection__title">{{ collection.title }}</h1>
    {% if intro != blank %}
      <read-more class="collection__intro">
        <div class="collection__intro-text rte" data-clamp>{{ intro }}</div>
        <button
          type="button"
          class="collection__intro-toggle"
          data-toggle
          data-more="{{ 'collection.read_more' | t | escape }}"
          data-less="{{ 'collection.read_less' | t | escape }}"
          hidden
        >
          {{ 'collection.read_more' | t }}
        </button>
      </read-more>
    {% endif %}
  </header>

  {% if section.settings.category_nav != blank %}
    <nav class="cat-strip" aria-label="{{ 'collections.title' | t }}">
      {% for nav_collection in section.settings.category_nav %}
        {% liquid
          assign nh = nav_collection.handle | downcase
          assign cat_label = nav_collection.title
          if nh contains 'surf'
            assign cat_label = 'collection.cat.surf' | t
          elsif nh contains 'skate'
            assign cat_label = 'collection.cat.skate' | t
          elsif nh contains 'snow'
            assign cat_label = 'collection.cat.snowboard' | t
          elsif nh contains 'ski'
            assign cat_label = 'collection.cat.skis' | t
          elsif nh contains 'bike' or nh contains 'velo'
            assign cat_label = 'collection.cat.bike' | t
          elsif nh contains 'kite' or nh contains 'wake'
            assign cat_label = 'collection.cat.wake' | t
          elsif nh contains 'deco'
            assign cat_label = 'collection.cat.deco' | t
          endif
        %}
        <a
          class="cat-chip{% if nav_collection.handle == collection.handle %} is-active{% endif %}"
          href="{{ nav_collection.url }}"
          {% if nav_collection.handle == collection.handle %}aria-current="page"{% endif %}
        >
          <span class="cat-chip__icon">{% render 'sports-icon', handle: nav_collection.handle %}</span>
          <span class="cat-chip__label">{{ cat_label }}</span>
        </a>
      {% endfor %}
    </nav>
  {% endif %}

  {% paginate collection.products by section.settings.products_per_page %}
    <div class="collection__bar">
      <div class="collection__filters-row">
        <details class="facet facet--sort">
          <summary class="facet__pill">
            <svg viewBox="0 0 20 20" width="15" height="15" aria-hidden="true" focusable="false"><path d="M6 4v12M6 16l-3-3M6 4l3 3M14 16V4M14 4l3 3M14 16l-3-3" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {{ 'collection.sort_by' | t }}
          </summary>
          <div class="facet__panel">
            {% for option in collection.sort_options %}
              <button
                type="button"
                class="facet__sort-option{% if option.value == sort_by %} is-active{% endif %}"
                data-sort-value="{{ option.value }}"
              >
                {{ option.name }}
              </button>
            {% endfor %}
          </div>
        </details>

        {% if collection.filters.size > 0 %}
          <facet-filters class="facet-bar">
            <form method="get">
              {% for filter in collection.filters %}
                <details class="facet">
                  <summary class="facet__pill">
                    {{ filter.label }}
                    <svg viewBox="0 0 20 20" width="15" height="15" aria-hidden="true" focusable="false"><path d="M5 8l5 5 5-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </summary>
                  <div class="facet__panel">
                    {% case filter.type %}
                      {% when 'price_range' %}
                        <div class="facet__price">
                          <input
                            type="number"
                            name="{{ filter.min_value.param_name }}"
                            value="{{ filter.min_value.value }}"
                            placeholder="0"
                            min="0"
                          >
                          <span>–</span>
                          <input
                            type="number"
                            name="{{ filter.max_value.param_name }}"
                            value="{{ filter.max_value.value }}"
                            placeholder="{{ filter.range_max | money_without_currency }}"
                            min="0"
                          >
                        </div>
                      {% else %}
                        <ul class="facet__values" role="list">
                          {% for value in filter.values %}
                            <li>
                              <label class="facet__value{% if value.count == 0 and value.active == false %} is-disabled{% endif %}">
                                <input
                                  type="checkbox"
                                  name="{{ value.param_name }}"
                                  value="{{ value.value }}"
                                  {% if value.active %}checked{% endif %}
                                  {% if value.count == 0 and value.active == false %}disabled{% endif %}
                                >
                                <span>{{ value.label }} ({{ value.count }})</span>
                              </label>
                            </li>
                          {% endfor %}
                        </ul>
                    {% endcase %}
                  </div>
                </details>
              {% endfor %}

              {% if collection.sort_by != blank %}
                <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
              {% endif %}
              <noscript><button type="submit" class="facet__apply">{{ 'collection.apply' | t }}</button></noscript>
            </form>
          </facet-filters>

          <a class="facet__clear-all" href="{{ collection.url }}">{{ 'collection.clear_all' | t }}</a>
        {% endif %}
      </div>

      <span class="collection__count">
        {{ 'collection.results_html' | t: count: collection.products_count }}
      </span>
    </div>

    {% if collection.products.size > 0 %}
      <div class="collection__grid">
        {% for product in collection.products %}
          {% render 'product-card', card_product: product, sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw' %}
        {% endfor %}
      </div>
      <div class="collection__pagination">{{ paginate | default_pagination }}</div>
    {% else %}
      <p class="collection__empty">{{ 'collection.empty' | t }}</p>
    {% endif %}
  {% endpaginate %}

  {% if collection.metafields.custom.seo_body != blank %}
    <div class="collection__seo rte">{{ collection.metafields.custom.seo_body | metafield_tag }}</div>
  {% endif %}

  {% if faq != blank and faq.size > 0 %}
    <section class="collection__faq">
      <h2 class="collection__faq-title">{{ 'collection.faq_title' | t }}</h2>
      {% for item in faq %}
        <details class="accordion">
          <summary class="accordion__summary">
            {{ item.question }}
            <svg class="accordion__chevron" viewBox="0 0 20 20" width="18" height="18" aria-hidden="true" focusable="false"><path d="M5 8l5 5 5-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="accordion__content rte">{{ item.answer }}</div>
        </details>
      {% endfor %}
    </section>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {% for item in faq %}
            {
              "@type": "Question",
              "name": {{ item.question | json }},
              "acceptedAnswer": { "@type": "Answer", "text": {{ item.answer | strip_html | json }} }
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]
      }
    </script>
  {% endif %}

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ 'general.home' | t | json }},
          "item": {{ shop.url | append: routes.root_url | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": {{ shop.url | append: collection.url | json }}
        }
      ]
    }
  </script>
</div>

{% stylesheet %}
  .collection {
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 1.5rem var(--rar-page-margin) 4rem;
  }

  .breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0 0 1.5rem;
    padding: 0;
    list-style: none;
    font-size: 0.8125rem;
    color: rgb(28 40 48 / 55%);
  }
  .breadcrumbs__item + .breadcrumbs__item::before {
    content: '/';
    margin-inline-end: 0.4rem;
    color: rgb(28 40 48 / 35%);
  }
  .breadcrumbs__item a {
    color: inherit;
    text-decoration: none;
  }
  .breadcrumbs__item a:hover {
    color: var(--rar-accent);
  }

  /* Centered header */
  .collection__header {
    max-width: 760px;
    margin: 1rem auto 2.5rem;
    text-align: center;
  }
  .collection__title {
    margin: 0 0 1rem;
    font-size: clamp(1.85rem, 1.2rem + 2.4vw, 3rem);
  }
  .collection__intro-text {
    color: rgb(28 40 48 / 75%);
    line-height: 1.6;
  }
  read-more[data-collapsed] .collection__intro-text {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .collection__intro-toggle {
    margin-top: 0.5rem;
    padding: 0;
    border: 0;
    background: none;
    color: var(--rar-accent);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }

  /* Sport-icon category switcher */
  .cat-strip {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin: 0 0 2.5rem;
    padding-bottom: 0.5rem;
  }
  .cat-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    min-width: 4.5rem;
    color: rgb(28 40 48 / 65%);
    text-decoration: none;
  }
  .cat-chip__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.75rem;
    height: 3.75rem;
    border: 1.5px solid rgb(28 40 48 / 12%);
    border-radius: 50%;
    background-color: var(--rar-color-background);
    transition: border-color 0.18s ease, background-color 0.18s ease, color 0.18s ease;
  }
  .cat-chip__label {
    font-size: 0.8125rem;
    text-align: center;
    line-height: 1.2;
  }
  .cat-chip:hover .cat-chip__icon,
  .cat-chip.is-active .cat-chip__icon {
    border-color: var(--rar-accent);
    background-color: var(--rar-color-surface);
    color: var(--rar-accent);
  }
  .cat-chip.is-active {
    color: var(--rar-ink);
    font-weight: 600;
  }

  /* Horizontal filter bar */
  .collection__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgb(28 40 48 / 10%);
  }
  .collection__filters-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .facet-bar {
    display: contents;
  }
  .facet {
    position: relative;
  }
  .facet__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    border: 1.5px solid rgb(28 40 48 / 15%);
    border-radius: 999px;
    font-size: 0.875rem;
    white-space: nowrap;
    cursor: pointer;
    list-style: none;
  }
  .facet__pill::-webkit-details-marker {
    display: none;
  }
  .facet[open] .facet__pill {
    border-color: var(--rar-color-ink);
  }
  .facet[open] .facet__pill svg {
    transform: rotate(180deg);
  }
  .facet__panel {
    position: absolute;
    z-index: 30;
    inset-block-start: calc(100% + 0.4rem);
    inset-inline-start: 0;
    min-width: 14rem;
    max-height: 20rem;
    overflow-y: auto;
    padding: 1rem;
    background-color: var(--rar-color-background);
    border-radius: var(--rar-radius-card);
    box-shadow: 0 12px 32px rgb(28 40 48 / 14%);
  }
  .facet__values {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .facet__value {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    cursor: pointer;
  }
  .facet__value.is-disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .facet__price {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .facet__price input {
    width: 100%;
    padding: 0.5rem;
    border: 1.5px solid rgb(28 40 48 / 20%);
    border-radius: var(--rar-radius-button);
  }
  .facet__sort-option {
    display: block;
    width: 100%;
    padding: 0.5rem 0.6rem;
    border: 0;
    border-radius: var(--rar-radius-button);
    background: none;
    text-align: start;
    font: inherit;
    cursor: pointer;
  }
  .facet__sort-option:hover {
    background-color: var(--rar-color-surface);
  }
  .facet__sort-option.is-active {
    color: var(--rar-accent);
    font-weight: 600;
  }
  .facet__apply {
    margin-top: 0.75rem;
    padding: 0.5rem 1rem;
    border: 0;
    border-radius: var(--rar-radius-button);
    background-color: var(--rar-accent);
    color: #fff;
    cursor: pointer;
  }
  .facet__clear-all {
    color: var(--rar-accent);
    font-size: 0.8125rem;
    white-space: nowrap;
  }
  .collection__count {
    color: rgb(28 40 48 / 55%);
    font-size: 0.875rem;
    white-space: nowrap;
  }

  .collection__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .collection__pagination {
    margin-top: 2.5rem;
    text-align: center;
  }
  .collection__empty {
    padding: 3rem 0;
    text-align: center;
    color: rgb(28 40 48 / 60%);
  }

  .collection__seo {
    max-width: 800px;
    margin: 4rem auto 0;
    padding-top: 2.5rem;
    border-top: 1px solid rgb(28 40 48 / 10%);
    color: rgb(28 40 48 / 85%);
    line-height: 1.7;
  }

  .collection__faq {
    max-width: 800px;
    margin: 3rem auto 0;
  }
  .collection__faq-title {
    margin: 0 0 1rem;
    font-size: clamp(1.5rem, 1.1rem + 1.4vw, 2rem);
    text-align: center;
  }
  .collection__faq .accordion {
    border-bottom: 1px solid rgb(28 40 48 / 10%);
  }
  .collection__faq .accordion__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    font-family: var(--rar-font-heading);
    font-size: 1.0625rem;
    cursor: pointer;
    list-style: none;
  }
  .collection__faq .accordion__summary::-webkit-details-marker {
    display: none;
  }
  .collection__faq .accordion__chevron {
    flex: 0 0 auto;
    transition: transform 0.2s ease;
  }
  .collection__faq .accordion[open] .accordion__chevron {
    transform: rotate(180deg);
  }
  .collection__faq .accordion__content {
    padding: 0 0 1.25rem;
    color: rgb(28 40 48 / 80%);
    font-size: 0.9375rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (max-width: 749px) {
    .cat-strip {
      justify-content: flex-start;
      gap: 1rem;
      overflow-x: auto;
      scrollbar-width: none;
      margin-inline: calc(-1 * var(--rar-page-margin));
      padding-inline: var(--rar-page-margin);
    }
    .cat-strip::-webkit-scrollbar {
      display: none;
    }
    .cat-chip {
      flex: 0 0 auto;
    }
  }
  @media (min-width: 750px) {
    .collection__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }
  }
  @media (min-width: 990px) {
    .collection__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
{% endstylesheet %}

{% javascript %}
  class ReadMore extends HTMLElement {
    connectedCallback() {
      this.text = this.querySelector('[data-clamp]');
      this.toggle = this.querySelector('[data-toggle]');
      if (!this.text || !this.toggle) return;

      requestAnimationFrame(() => {
        this.setAttribute('data-collapsed', '');
        if (this.text.scrollHeight - this.text.clientHeight > 4) {
          this.toggle.hidden = false;
        } else {
          this.removeAttribute('data-collapsed');
        }
      });

      this.toggle.addEventListener('click', () => {
        if (this.hasAttribute('data-collapsed')) {
          this.removeAttribute('data-collapsed');
          this.toggle.textContent = this.toggle.dataset.less;
        } else {
          this.setAttribute('data-collapsed', '');
          this.toggle.textContent = this.toggle.dataset.more;
        }
      });
    }
  }
  if (!customElements.get('read-more')) {
    customElements.define('read-more', ReadMore);
  }

  class FacetFilters extends HTMLElement {
    connectedCallback() {
      this.form = this.querySelector('form');
      if (this.form) this.form.addEventListener('change', () => this.form.submit());
    }
  }
  if (!customElements.get('facet-filters')) {
    customElements.define('facet-filters', FacetFilters);
  }

  document.addEventListener('click', (event) => {
    const option = event.target.closest('[data-sort-value]');
    if (!option) return;
    const url = new URL(window.location.href);
    url.searchParams.set('sort_by', option.dataset.sortValue);
    url.searchParams.delete('page');
    window.location.href = url.toString();
  });

  // Close any open facet dropdown when clicking outside of it
  document.addEventListener('click', (event) => {
    document.querySelectorAll('.facet[open]').forEach((facet) => {
      if (!facet.contains(event.target)) facet.removeAttribute('open');
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:labels.products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "collection_list",
      "id": "category_nav",
      "label": "t:labels.category_nav",
      "info": "t:info.category_nav"
    }
  ]
}
{% endschema %}
