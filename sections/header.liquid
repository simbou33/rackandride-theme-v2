{% comment %}
  Global header. Full-width sticky bar with on-scroll-up behavior: visible at
  the top of the page, hides when scrolling down, reappears when scrolling up.
  Holds the brand logo, a category navigation with one level of dropdowns
  (driven by a Shopify menu / linklist), and the account / search / cart icons.
  The cart icon opens the global cart drawer (data-cart-toggle).
{% endcomment %}

<sticky-header class="header full-width" data-sticky>
  <div class="header__bar">
    {% render 'logo', size: 44 %}

    {% if section.settings.menu != blank %}
      <nav class="header__nav" aria-label="{{ 'general.accessibility.menu' | t }}">
        <ul class="header__menu" role="list">
          {% for link in section.settings.menu.links %}
            <li
              class="header__item{% if link.links.size > 0 %} header__item--has-children{% endif %}"
            >
              <a
                class="header__link"
                href="{{ link.url }}"
                {% if link.current or link.child_active %}
                  aria-current="page"
                {% endif %}
              >
                {{ link.title }}
              </a>

              {% if link.links.size > 0 %}
                <div class="header__dropdown">
                  <ul class="header__submenu" role="list">
                    {% for child in link.links %}
                      <li>
                        <a
                          class="header__sublink"
                          href="{{ child.url }}"
                          {% if child.current %}
                            aria-current="page"
                          {% endif %}
                        >
                          {{ child.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    <div class="header__icons">
      <div class="header__locale">
        {% render 'language-selector', id_prefix: 'hdr' %}
      </div>

      {% if shop.customer_accounts_enabled %}
        <shopify-account
          class="header__icon"
          menu="{{ section.settings.customer_account_menu }}"
        >
          <span class="visually-hidden">{{ 'general.accessibility.account' | t }}</span>
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a class="header__icon" href="{{ routes.search_url }}">
        <span class="visually-hidden">{{ 'general.accessibility.search' | t }}</span>
        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" focusable="false">
          <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </a>

      <a
        class="header__icon header__cart"
        href="{{ routes.cart_url }}"
        data-cart-toggle
        aria-label="{{ 'general.accessibility.cart_drawer' | t }}"
      >
        <sup class="header__cart-count" data-cart-count{% if cart.item_count == 0 %} hidden{% endif %}>
          {{- cart.item_count -}}
        </sup>
        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>

      {% if section.settings.menu != blank %}
        <button
          type="button"
          class="header__icon header__burger"
          data-menu-open
          aria-label="{{ 'general.accessibility.menu' | t }}"
          aria-expanded="false"
        >
          <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" focusable="false">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
        </button>
      {% endif %}
    </div>
  </div>
</sticky-header>

{% if section.settings.menu != blank %}
  <mobile-nav>
    <dialog class="mobile-nav__dialog" scroll-lock aria-label="{{ 'general.accessibility.menu' | t }}">
      <div class="mobile-nav__panel">
        <div class="mobile-nav__head">
          {% render 'logo', size: 36 %}
          <button
            type="button"
            class="mobile-nav__close"
            data-menu-close
            aria-label="{{ 'general.accessibility.close' | t }}"
          >
            <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true" focusable="false"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
          </button>
        </div>

        <ul class="mobile-nav__list" role="list">
          {% for link in section.settings.menu.links %}
            <li>
              {% if link.links.size > 0 %}
                <details class="mobile-nav__group">
                  <summary class="mobile-nav__summary">
                    {{ link.title }}
                    <svg viewBox="0 0 20 20" width="18" height="18" aria-hidden="true" focusable="false"><path d="M5 8l5 5 5-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </summary>
                  <ul class="mobile-nav__sublist" role="list">
                    <li>
                      <a class="mobile-nav__sublink" href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                    {% for child in link.links %}
                      <li>
                        <a class="mobile-nav__sublink" href="{{ child.url }}">{{ child.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </details>
              {% else %}
                <a class="mobile-nav__link" href="{{ link.url }}">{{ link.title }}</a>
              {% endif %}
            </li>
          {% endfor %}
        </ul>

        <div class="mobile-nav__locale">
          {% render 'language-selector', id_prefix: 'mob' %}
        </div>
      </div>
    </dialog>
  </mobile-nav>
{% endif %}

{% stylesheet %}
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--rar-color-background);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .header[data-hidden] {
    transform: translateY(-100%);
  }
  .header[data-scrolled] {
    box-shadow: 0 1px 0 rgb(28 40 48 / 8%);
  }

  .header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    width: 100%;
    max-width: var(--rar-page-width);
    min-height: 5rem;
    margin-inline: auto;
    padding-inline: var(--rar-page-margin);
  }

  .header__nav {
    flex: 1 1 auto;
  }
  .header__menu {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .header__item {
    position: relative;
  }
  .header__link,
  .header__sublink {
    display: inline-block;
    color: var(--rar-text);
    font-size: 0.9375rem;
    text-decoration: none;
  }
  .header__link {
    padding: 0.5rem 0;
  }
  .header__link::after {
    content: '';
    display: block;
    height: 1.5px;
    margin-top: 2px;
    background-color: var(--rar-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }
  .header__link:hover::after,
  .header__item:focus-within > .header__link::after,
  .header__link[aria-current='page']::after {
    transform: scaleX(1);
  }

  .header__dropdown {
    position: absolute;
    inset-inline-start: 0;
    top: 100%;
    z-index: 60;
    min-width: 13rem;
    padding-top: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
  }
  .header__item--has-children:hover .header__dropdown,
  .header__item--has-children:focus-within .header__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .header__submenu {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: 0;
    padding: 0.75rem;
    list-style: none;
    background-color: var(--rar-color-background);
    border-radius: var(--rar-radius-card);
    box-shadow: 0 12px 32px rgb(28 40 48 / 12%);
  }
  .header__sublink {
    padding: 0.5rem 0.75rem;
    border-radius: var(--rar-radius-button);
    white-space: nowrap;
  }
  .header__sublink:hover,
  .header__sublink[aria-current='page'] {
    background-color: var(--rar-color-surface);
    color: var(--rar-accent);
  }

  .header__icons {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .header__icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--rar-text);
    text-decoration: none;
    cursor: pointer;
  }
  .header__icon:hover {
    color: var(--rar-accent);
  }
  .header__icon svg {
    width: 1.5rem;
    height: 1.5rem;
  }
  .header__cart-count {
    position: absolute;
    inset-block-start: -0.4rem;
    inset-inline-start: 100%;
    min-width: 1.1rem;
    margin-inline-start: -0.4rem;
    padding: 0 0.3rem;
    border-radius: 1rem;
    background-color: var(--rar-accent);
    color: #fff;
    font-size: 0.6875rem;
    line-height: 1.1rem;
    text-align: center;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  /* Hamburger — mobile only */
  .header__burger {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--rar-text);
    cursor: pointer;
  }
  .header__burger svg {
    width: 1.6rem;
    height: 1.6rem;
  }

  /* Mobile navigation drawer (left) */
  .mobile-nav__dialog {
    position: fixed;
    inset: 0 0 0 auto;
    z-index: 100;
    width: min(86vw, 360px);
    max-width: 100%;
    height: 100dvh;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    border: 0;
    background-color: var(--rar-color-background);
    color: var(--rar-text);
    box-shadow: -8px 0 40px rgb(28 40 48 / 12%);
    transform: translateX(0);
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      overlay 0.3s allow-discrete,
      display 0.3s allow-discrete;
  }
  .mobile-nav__dialog:not([open]) {
    transform: translateX(100%);
  }
  @starting-style {
    .mobile-nav__dialog[open] {
      transform: translateX(100%);
    }
  }
  .mobile-nav__dialog::backdrop {
    background-color: rgb(28 40 48 / 0%);
    transition:
      background-color 0.3s ease,
      overlay 0.3s allow-discrete,
      display 0.3s allow-discrete;
  }
  .mobile-nav__dialog[open]::backdrop {
    background-color: rgb(28 40 48 / 45%);
  }
  @starting-style {
    .mobile-nav__dialog[open]::backdrop {
      background-color: rgb(28 40 48 / 0%);
    }
  }
  .mobile-nav__panel {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow-y: auto;
  }
  .mobile-nav__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgb(28 40 48 / 8%);
  }
  .mobile-nav__close {
    display: inline-flex;
    width: 2.5rem;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    border-radius: var(--rar-radius-button);
    background: transparent;
    color: var(--rar-text);
    cursor: pointer;
  }
  .mobile-nav__list {
    margin: 0;
    padding: 0.5rem 0;
    list-style: none;
  }
  .mobile-nav__link,
  .mobile-nav__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1.5rem;
    color: var(--rar-text);
    font-family: var(--rar-font-heading);
    font-size: 1.0625rem;
    text-decoration: none;
    cursor: pointer;
    list-style: none;
  }
  .mobile-nav__summary::-webkit-details-marker {
    display: none;
  }
  .mobile-nav__group[open] .mobile-nav__summary svg {
    transform: rotate(180deg);
  }
  .mobile-nav__summary svg {
    transition: transform 0.2s ease;
  }
  .mobile-nav__sublist {
    margin: 0;
    padding: 0 0 0.5rem;
    list-style: none;
  }
  .mobile-nav__sublink {
    display: block;
    padding: 0.6rem 1.5rem 0.6rem 2.25rem;
    color: rgb(28 40 48 / 75%);
    font-size: 0.95rem;
    text-decoration: none;
  }
  .mobile-nav__sublink:hover {
    color: var(--rar-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-nav__dialog,
    .mobile-nav__dialog::backdrop {
      transition: none;
    }
    .mobile-nav__dialog:not([open]) {
      transform: none;
    }
  }

  .mobile-nav__locale {
    margin-top: auto;
    padding: 1rem 1.25rem;
    border-top: 1px solid rgb(28 40 48 / 8%);
  }

  @media (max-width: 749px) {
    .header__nav {
      display: none;
    }
    .header__burger {
      display: inline-flex;
    }
    .header__locale {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  class StickyHeader extends HTMLElement {
    connectedCallback() {
      this.lastY = window.scrollY;
      this.ticking = false;
      this.handler = this.onScroll.bind(this);
      window.addEventListener('scroll', this.handler, { passive: true });
    }

    disconnectedCallback() {
      window.removeEventListener('scroll', this.handler);
    }

    onScroll() {
      if (this.ticking) return;
      this.ticking = true;
      window.requestAnimationFrame(() => {
        const y = window.scrollY;
        if (y <= 0) {
          this.removeAttribute('data-scrolled');
          this.removeAttribute('data-hidden');
        } else {
          this.setAttribute('data-scrolled', '');
          if (y > this.lastY && y - this.lastY > 4 && y > 120) {
            this.setAttribute('data-hidden', '');
          } else if (y < this.lastY) {
            this.removeAttribute('data-hidden');
          }
        }
        this.lastY = y;
        this.ticking = false;
      });
    }
  }

  if (!customElements.get('sticky-header')) {
    customElements.define('sticky-header', StickyHeader);
  }

  class MobileNav extends HTMLElement {
    connectedCallback() {
      this.dialog = this.querySelector('dialog');
      if (!this.dialog) return;

      document.addEventListener('click', (event) => {
        if (event.target.closest('[data-menu-open]')) {
          event.preventDefault();
          this.open();
        }
      });
      this.addEventListener('click', (event) => {
        if (event.target.closest('[data-menu-close]')) {
          event.preventDefault();
          this.close();
        }
      });
      this.dialog.addEventListener('click', (event) => {
        if (event.target === this.dialog) this.close();
      });
    }

    open() {
      if (!this.dialog.open) this.dialog.showModal();
      const trigger = document.querySelector('[data-menu-open]');
      if (trigger) trigger.setAttribute('aria-expanded', 'true');
    }

    close() {
      if (this.dialog.open) this.dialog.close();
      const trigger = document.querySelector('[data-menu-open]');
      if (trigger) trigger.setAttribute('aria-expanded', 'false');
    }
  }
  if (!customElements.get('mobile-nav')) {
    customElements.define('mobile-nav', MobileNav);
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
