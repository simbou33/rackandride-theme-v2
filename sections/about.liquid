{% comment %}
  About / "Our story" page. A brand-story intro followed by an editable team
  grid (member blocks: photo + name + role + bio). Team photos can come from the
  theme/assets via `image_asset` or from a picked image. Text is editable and
  translatable (Translate & Adapt).
{% endcomment %}

<section class="about">
  <header class="about__intro">
    {% if section.settings.heading != blank %}
      <h1 class="about__title">{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.body != blank %}
      <div class="about__body rte">{{ section.settings.body }}</div>
    {% endif %}
  </header>

  {% if section.blocks.size > 0 %}
    <div class="about__team">
      {% if section.settings.team_heading != blank %}
        <h2 class="about__team-title">{{ section.settings.team_heading }}</h2>
      {% endif %}

      <div class="about__grid">
        {% for block in section.blocks %}
          {% if block.type == 'member' %}
            <figure class="member" {{ block.shopify_attributes }}>
              <div class="member__media">
                {% if block.settings.image %}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      widths: '300, 400, 600, 800',
                      sizes: '(min-width: 750px) 33vw, 100vw',
                      loading: 'lazy',
                      alt: block.settings.name
                  }}
                {% elsif block.settings.image_asset != blank %}
                  <img
                    src="{{ block.settings.image_asset | asset_url }}"
                    alt="{{ block.settings.name | escape }}"
                    width="1536"
                    height="2048"
                    loading="lazy"
                  >
                {% endif %}
              </div>
              <figcaption class="member__caption">
                {% if block.settings.name != blank %}
                  <span class="member__name">{{ block.settings.name }}</span>
                {% endif %}
                {% if block.settings.role != blank %}
                  <span class="member__role">{{ block.settings.role }}</span>
                {% endif %}
                {% if block.settings.bio != blank %}
                  <div class="member__bio rte">{{ block.settings.bio }}</div>
                {% endif %}
              </figcaption>
            </figure>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .about {
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 3rem var(--rar-page-margin) 4rem;
  }
  .about__intro {
    max-width: 760px;
    margin: 0 auto 3.5rem;
    text-align: center;
  }
  .about__title {
    margin: 0 0 1.25rem;
    font-size: clamp(2rem, 1.4rem + 2.6vw, 3rem);
  }
  .about__body {
    color: rgb(28 40 48 / 80%);
    line-height: 1.75;
    font-size: 1.0625rem;
  }
  .about__team-title {
    margin: 0 0 2.5rem;
    font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.25rem);
    text-align: center;
  }
  .about__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .member {
    margin: 0;
  }
  .member__media {
    aspect-ratio: 3 / 4;
    margin-bottom: 1.1rem;
    border-radius: var(--rar-radius-card);
    overflow: hidden;
    background-color: var(--rar-color-surface);
  }
  .member__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .member__name {
    display: block;
    font-family: var(--rar-font-heading);
    font-size: 1.25rem;
    font-weight: 600;
  }
  .member__role {
    display: block;
    margin-bottom: 0.6rem;
    color: var(--rar-accent);
    font-size: 0.875rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .member__bio {
    color: rgb(28 40 48 / 75%);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  @media (min-width: 750px) {
    .about__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.about",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Our story"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "t:labels.text"
    },
    {
      "type": "text",
      "id": "team_heading",
      "label": "t:labels.heading",
      "default": "The team behind Rack And Ride"
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "t:general.team_member",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "t:labels.image_asset",
          "info": "t:info.image_asset"
        },
        {
          "type": "text",
          "id": "name",
          "label": "t:labels.name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "t:labels.role"
        },
        {
          "type": "richtext",
          "id": "bio",
          "label": "t:labels.bio"
        }
      ]
    }
  ],
  "presets": [{ "name": "t:general.about" }]
}
{% endschema %}
