{% comment %}
  Homepage newsletter sign-up. Centered heading + text + email form (Shopify
  customer form, tagged "newsletter"). UI strings are translated.
{% endcomment %}

<section class="newsletter">
  <div class="newsletter__inner">
    {% if section.settings.heading != blank %}
      <h2 class="newsletter__title">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.text != blank %}
      <div class="newsletter__text rte">{{ section.settings.text }}</div>
    {% endif %}

    {% form 'customer', class: 'newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {% if form.posted_successfully? %}
        <p class="newsletter__success">{{ 'newsletter.success' | t }}</p>
      {% else %}
        <div class="newsletter__field">
          <label class="visually-hidden" for="NewsletterHome-email">{{ 'newsletter.email_label' | t }}</label>
          <input
            id="NewsletterHome-email"
            type="email"
            name="contact[email]"
            class="newsletter__input"
            placeholder="{{ 'newsletter.email_label' | t }}"
            autocomplete="email"
            required
          >
          <button type="submit" class="newsletter__button">{{ 'newsletter.button' | t }}</button>
        </div>
      {% endif %}
    {% endform %}
  </div>
</section>

{% stylesheet %}
  .newsletter {
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 4rem var(--rar-page-margin);
  }
  .newsletter__inner {
    max-width: 560px;
    margin-inline: auto;
    text-align: center;
  }
  .newsletter__title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.75rem, 1.2rem + 2vw, 2.5rem);
  }
  .newsletter__text {
    margin-bottom: 1.5rem;
    color: rgb(28 40 48 / 75%);
  }
  .newsletter__field {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }
  .newsletter__input {
    flex: 1 1 auto;
    min-width: 0;
    max-width: 22rem;
    padding: 0.75rem 1rem;
    border: 1.5px solid rgb(28 40 48 / 20%);
    border-radius: var(--rar-radius-button);
    background-color: var(--rar-color-background);
    color: var(--rar-text);
  }
  .newsletter__button {
    flex: 0 0 auto;
    padding: 0.75rem 1.5rem;
    border: 0;
    border-radius: var(--rar-radius-button);
    background-color: var(--rar-accent);
    color: #fff;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }
  .newsletter__button:hover {
    filter: brightness(0.94);
  }
  .newsletter__success {
    color: var(--rar-eco);
    font-weight: 600;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Join the workshop"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:labels.text",
      "default": "<p>New designs, behind-the-scenes from Les Landes, and the occasional offer.</p>"
    }
  ],
  "presets": [{ "name": "t:general.newsletter" }],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
