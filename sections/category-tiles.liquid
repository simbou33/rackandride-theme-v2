{% comment %}
  Category tiles: a grid of collection cards (collection image, or first
  product image as fallback) with the collection title and a link. Block-based
  (one block per collection). Renders nothing if no collection is set.
{% endcomment %}

{% if section.blocks.size > 0 %}
  <section class="categories">
    {% if section.settings.heading != blank %}
      <div class="categories__header">
        <h2 class="categories__title">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="categories__grid">
      {% for block in section.blocks %}
        {% liquid
          assign collection = block.settings.collection
          assign tile_image = block.settings.image | default: collection.image
          unless tile_image
            assign tile_image = collection.products.first.featured_media.preview_image
          endunless
          assign tile_title = block.settings.custom_title | default: collection.title
        %}
        {% if collection != blank %}
          <a class="category-tile" href="{{ collection.url }}" {{ block.shopify_attributes }}>
            <div class="category-tile__media">
              {% if tile_image %}
                {{
                  tile_image
                  | image_url: width: 800
                  | image_tag:
                    widths: '300, 400, 600, 800',
                    sizes: '(min-width: 750px) 25vw, 50vw',
                    loading: 'lazy',
                    alt: tile_title
                }}
              {% endif %}
            </div>
            <span class="category-tile__label">
              {{ tile_title }}
              <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true" focusable="false"><path d="M5 10h10M11 6l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .categories {
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 4rem var(--rar-page-margin);
  }
  .categories__header {
    margin-bottom: 2rem;
    text-align: center;
  }
  .categories__title {
    margin: 0;
    font-size: clamp(1.75rem, 1.2rem + 2vw, 2.5rem);
  }
  .categories__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .category-tile {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .category-tile__media {
    aspect-ratio: 3 / 4;
    margin-bottom: 0.75rem;
    border-radius: var(--rar-radius-card);
    overflow: hidden;
    background-color: var(--rar-color-surface);
  }
  .category-tile__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .category-tile:hover .category-tile__media img {
    transform: scale(1.04);
  }
  .category-tile__label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--rar-font-heading);
    font-size: 1.125rem;
    font-weight: 600;
  }
  .category-tile__label svg {
    transition: transform 0.2s ease;
  }
  .category-tile:hover .category-tile__label svg {
    transform: translateX(3px);
    color: var(--rar-accent);
  }
  @media (min-width: 750px) {
    .categories__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.category_tiles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Shop by sport"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "t:general.category_tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:general.collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image",
          "info": "t:info.tile_image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "t:labels.custom_title"
        }
      ]
    }
  ],
  "presets": [{ "name": "t:general.category_tiles" }],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
