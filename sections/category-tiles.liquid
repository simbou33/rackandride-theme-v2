{% comment %}
  Category tiles: a grid of collection cards (collection image, or first
  product image as fallback) with the collection title and a link. Block-based
  (one block per collection). Renders nothing if no collection is set.
{% endcomment %}

{% if section.blocks.size > 0 %}
  <section class="categories full-width{% if section.settings.surface_background %} categories--surface{% endif %}">
    <div class="categories__inner">
    {% if section.settings.heading != blank %}
      <div class="categories__header">
        <h2 class="categories__title">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="categories__grid">
      {% for block in section.blocks %}
        {% liquid
          assign collection = block.settings.collection
          assign tile_title = block.settings.custom_title | default: collection.title
          assign handle = collection.handle
          assign icon = block.settings.icon_asset
          if icon == blank
            if handle contains 'kite' or handle contains 'wake'
              assign icon = 'cat-kite-surf.svg'
            elsif handle contains 'surf'
              assign icon = 'cat-surf.svg'
            elsif handle contains 'skate'
              assign icon = 'cat-skate.svg'
            elsif handle contains 'snowboard'
              assign icon = 'cat-snowboard.svg'
            elsif handle contains 'ski'
              assign icon = 'cat-skis.svg'
            elsif handle contains 'bike'
              assign icon = 'cat-bike.svg'
            elsif handle contains 'deco'
              assign icon = 'cat-deco.svg'
            endif
          endif
          assign tile_image = block.settings.image | default: collection.image
        %}
        {% if collection != blank %}
          <a class="category-tile" href="{{ collection.url }}" {{ block.shopify_attributes }}>
            <div class="category-tile__icon">
              {% if icon != blank %}
                {{ icon | inline_asset_content }}
              {% elsif tile_image %}
                {{ tile_image | image_url: width: 300 | image_tag: loading: 'lazy', alt: tile_title }}
              {% endif %}
            </div>
            <span class="category-tile__label">{{ tile_title }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .categories {
    width: 100%;
  }
  .categories--surface {
    background-color: var(--rar-color-surface);
  }
  .categories__inner {
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 4.5rem var(--rar-page-margin);
  }
  .categories__header {
    margin-bottom: 2rem;
    text-align: center;
  }
  .categories__title {
    margin: 0;
    font-size: clamp(1.75rem, 1.2rem + 2vw, 2.5rem);
  }
  .categories__grid {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    /* Bleed to the page edges on mobile so the scroll is discoverable */
    margin-inline: calc(-1 * var(--rar-page-margin));
    padding: 0.25rem var(--rar-page-margin) 0.75rem;
  }
  .categories__grid::-webkit-scrollbar {
    display: none;
  }
  .category-tile {
    flex: 0 0 auto;
    width: clamp(104px, 30vw, 150px);
    scroll-snap-align: start;
    color: inherit;
    text-decoration: none;
  }
  .category-tile__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(76px, 16vw, 108px);
    aspect-ratio: 1;
    margin: 0 auto 0.85rem;
    border-radius: 50%;
    background-color: var(--rar-color-background);
    color: var(--rar-text);
    transition: color 0.2s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .category-tile__icon svg {
    width: 48%;
    height: auto;
  }
  .category-tile__icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .category-tile:hover .category-tile__icon {
    color: var(--rar-accent);
    transform: translateY(-4px);
    box-shadow: 0 10px 24px rgb(28 40 48 / 10%);
  }
  .category-tile__label {
    display: block;
    font-family: var(--rar-font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
  }
  /* On wider screens the tiles share one row with no scroll */
  @media (min-width: 990px) {
    .categories__grid {
      gap: 1.25rem;
      margin-inline: 0;
      padding-inline: 0;
    }
    .category-tile {
      flex: 1 1 0;
      width: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.category_tiles",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Shop by sport"
    },
    {
      "type": "checkbox",
      "id": "surface_background",
      "label": "t:labels.surface_background",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "t:general.category_tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:general.collection"
        },
        {
          "type": "text",
          "id": "icon_asset",
          "label": "t:labels.icon_asset",
          "info": "t:info.icon_asset"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image",
          "info": "t:info.tile_image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "t:labels.custom_title"
        }
      ]
    }
  ],
  "presets": [{ "name": "t:general.category_tiles" }],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
