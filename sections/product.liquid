{% comment %}
  Product page. Two-column layout: a sticky media gallery and the product
  information column in the brand-mandated order:
  title / price / variants / quantity → highlights (USP) → short description →
  add-to-cart / buy now → reassurance → collapsible details → hr → long description.

  Content is read from existing product metafields when present:
  - custom.key_features (rich text) → highlights / USP
  - custom.short_description (text) → short description
  - collapsible rows can each read an optional product metafield (ns/key),
    otherwise fall back to the block's own rich text (easy switch to per-product
    metafields later).

  A sticky add-to-cart bar appears once the main buy buttons scroll away, and a
  Product JSON-LD block is emitted (no AggregateRating — no reviews app yet).
{% endcomment %}

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign form_id = 'ProductForm-' | append: section.id
  assign key_features = product.metafields.custom.key_features
  assign short_description = product.metafields.custom.short_description

  # Detect a size option whose values end in "mm" (e.g. "90 mm") — generic, no
  # hardcoded handles, so a future sized product is covered automatically.
  assign mm_option = false
  for option in product.options_with_values
    assign first_value = option.values | first | strip | downcase
    assign tail = first_value | slice: -2, 2
    if tail == 'mm'
      assign mm_option = option
      break
    endif
  endfor

  # Parent collection for the breadcrumb (silo up-link). Prefer the routed
  # collection, else the first real category the product belongs to.
  assign bc_collection = collection
  unless bc_collection
    for c in product.collections
      unless c.handle == 'all' or c.handle == 'frontpage' or c.handle == 'bestsellers'
        assign bc_collection = c
        break
      endunless
    endfor
  endunless
%}

<section class="product" data-section-id="{{ section.id }}">
  <nav class="breadcrumbs product__breadcrumbs" aria-label="Breadcrumb">
    <ol class="breadcrumbs__list">
      <li class="breadcrumbs__item">
        <a href="{{ routes.root_url }}">{{ 'general.home' | t }}</a>
      </li>
      {% if bc_collection %}
        <li class="breadcrumbs__item">
          <a href="{{ bc_collection.url }}">{{ bc_collection.title }}</a>
        </li>
      {% endif %}
      <li class="breadcrumbs__item" aria-current="page">{{ product.title }}</li>
    </ol>
  </nav>

  <div class="product__layout">
    {% comment %} ---------- MEDIA GALLERY ---------- {% endcomment %}
    <product-gallery class="product__media">
      <div class="product__media-main">
        {% for media in product.media %}
          {% liquid
            assign media_loading = 'lazy'
            if forloop.first
              assign media_loading = 'eager'
            endif
          %}
          <div
            class="product__media-slide"
            data-media-id="{{ media.id }}"
            {% unless forloop.first %}
              hidden
            {% endunless %}
          >
            {% if media.media_type == 'image' %}
              {{
                media
                | image_url: width: 1400
                | image_tag:
                  widths: '400, 600, 800, 1000, 1200, 1400',
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  loading: media_loading,
                  alt: media.alt | default: product.title
              }}
            {% else %}
              {{ media | media_tag: image_size: '1400x' }}
            {% endif %}
          </div>
        {% else %}
          <div class="product__media-slide product__media-slide--placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'product__placeholder' }}
          </div>
        {% endfor %}
      </div>

      {% if product.media.size > 1 %}
        <div class="product__thumbs" role="list">
          {% for media in product.media %}
            <button
              type="button"
              class="product__thumb"
              data-thumb="{{ media.id }}"
              aria-label="{{ forloop.index }}"
              {% if forloop.first %}
                aria-current="true"
              {% endif %}
            >
              {{
                media.preview_image
                | image_url: width: 200
                | image_tag: widths: '100, 200', sizes: '80px', loading: 'lazy', alt: ''
              }}
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </product-gallery>

    {% comment %} ---------- INFO COLUMN ---------- {% endcomment %}
    <div class="product__info">
      <h1 class="product__title">{{ product.title }}</h1>

      <div class="product__rating" style="margin: 0.35rem 0 0.85rem">
        {% render 'shop-rating' %}
      </div>

      <div class="product__price" data-product-price>
        {{ current_variant.price | money }}
      </div>

      {% form 'product', product, id: form_id, class: 'product__form' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

        {% unless product.has_only_default_variant %}
          {% if mm_option %}
            {% for block in section.blocks %}
              {% if block.type == 'size_helper' %}
                {% liquid
                  assign is_snow = false
                  if product.type contains 'Snowboard'
                    assign is_snow = true
                  endif
                %}
                {% render 'size-helper',
                  option: mm_option,
                  margin: block.settings.margin,
                  is_snow: is_snow,
                  shopify_attributes: block.shopify_attributes
                %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}

          <variant-selector
            class="product__variants"
            data-url="{{ product.url }}"
          >
            <script type="application/json" data-variants>
              {
                {% for variant in product.variants %}
                  "{{ variant.id }}": {
                    "options": {{ variant.options | json }},
                    "available": {{ variant.available }},
                    "price": {{ variant.price | money | json }}
                  }{% unless forloop.last %},{% endunless %}
                {% endfor %}
              }
            </script>

            {% for option in product.options_with_values %}
              {%- liquid
                assign option_class = 'product__option'
                if mm_option and option.position == mm_option.position
                  assign option_class = 'product__option product__option--mm'
                endif
              -%}
              <fieldset class="{{ option_class }}">
                <legend class="product__option-label">{{ option.name }}</legend>
                <div class="product__swatches">
                  {% for value in option.values %}
                    <label class="product__swatch">
                      <input
                        type="radio"
                        name="option-{{ option.position }}"
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}
                          checked
                        {% endif %}
                      >
                      <span>{{ value }}</span>
                    </label>
                  {% endfor %}
                </div>
              </fieldset>
            {% endfor %}
          </variant-selector>
        {% endunless %}

        {% if short_description != blank %}
          <div class="product__short-description">{{ short_description | metafield_tag }}</div>
        {% endif %}

        <div class="product__quantity">
          <label class="product__quantity-label" for="Quantity-{{ section.id }}">
            {{ 'product.quantity' | t }}
          </label>
          <quantity-input class="product__quantity-control">
            <button
              type="button"
              class="product__quantity-button"
              data-quantity-minus
              aria-label="{{ 'cart.decrease' | t }}"
            >
              &minus;
            </button>
            <input
              type="number"
              id="Quantity-{{ section.id }}"
              class="product__quantity-input"
              name="quantity"
              value="1"
              min="1"
              inputmode="numeric"
            >
            <button
              type="button"
              class="product__quantity-button"
              data-quantity-plus
              aria-label="{{ 'cart.increase' | t }}"
            >
              &plus;
            </button>
          </quantity-input>
        </div>

        <div class="product__buy" data-buy-buttons>
          <button
            type="submit"
            name="add"
            class="product__atc"
            data-label-available="{{ 'product.add_to_cart' | t | escape }}"
            data-label-soldout="{{ 'product.sold_out' | t | escape }}"
            {% unless current_variant.available %}
              disabled
            {% endunless %}
          >
            <span data-add-label>
              {% if current_variant.available %}
                {{ 'product.add_to_cart' | t }}
              {% else %}
                {{ 'product.sold_out' | t }}
              {% endif %}
            </span>
          </button>
          {{ form | payment_button }}
          <p class="product__trust">
            <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true" focusable="false"><rect x="4" y="10" width="16" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 10V7a4 4 0 018 0v3" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
            {{ 'product.secure_checkout' | t }}
          </p>
        </div>
      {% endform %}

      {% if section.settings.show_reassurance %}
        <ul class="product__reassurance" role="list">
          <li class="product__reassurance-item">
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false"><path d="M12 3l2.5 5 5.5.8-4 3.9.9 5.5L12 21l-4.9 2.6.9-5.5-4-3.9 5.5-.8z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
            <span>{{ 'product.reassurance.handmade' | t }}</span>
          </li>
          <li class="product__reassurance-item">
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false"><path d="M12 21s-7-4-7-10a7 7 0 0114 0c0 6-7 10-7 10z" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M12 4c0 6 0 11 0 11" stroke="currentColor" stroke-width="1.4"/></svg>
            <span>{{ 'product.reassurance.eco' | t }}</span>
          </li>
          <li class="product__reassurance-item">
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>{{ 'product.reassurance.secure' | t }}</span>
          </li>
          <li class="product__reassurance-item">
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false"><path d="M3 7l9-4 9 4-9 4z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M3 7v10l9 4 9-4V7M12 11v10" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
            <span>{{ 'product.reassurance.packaging' | t }}</span>
          </li>
        </ul>
      {% endif %}

      {% if key_features != blank %}
        <div class="product__highlights">
          <h2 class="product__highlights-title">{{ 'product.highlights' | t }}</h2>
          <div class="product__usp rte">{{ key_features | metafield_tag }}</div>
        </div>
      {% endif %}

      {% liquid
        assign show_desc_acc = false
        if section.settings.show_long_description and product.description != blank
          assign show_desc_acc = true
        endif
      %}
      {% if section.blocks.size > 0 or show_desc_acc %}
        <div class="product__accordions">
          {% for block in section.blocks %}
            {% if block.type == 'collapsible' %}
              {% liquid
                assign content = block.settings.content
                assign ns = block.settings.metafield_namespace
                assign key = block.settings.metafield_key
                if ns != blank and key != blank
                  assign override = product.metafields[ns][key]
                  if override != blank
                    assign content = override
                  endif
                endif
              %}
              {% if block.settings.heading != blank or content != blank %}
                <details class="accordion" {{ block.shopify_attributes }}>
                  <summary class="accordion__summary">
                    {{ block.settings.heading }}
                    <svg class="accordion__chevron" viewBox="0 0 20 20" width="18" height="18" aria-hidden="true" focusable="false"><path d="M5 8l5 5 5-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </summary>
                  <div class="accordion__content rte">{{ content }}</div>
                </details>
              {% endif %}
            {% endif %}
          {% endfor %}

          {% if show_desc_acc %}
            <details class="accordion">
              <summary class="accordion__summary">
                {{ 'product.full_description' | t }}
                <svg class="accordion__chevron" viewBox="0 0 20 20" width="18" height="18" aria-hidden="true" focusable="false"><path d="M5 8l5 5 5-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </summary>
              <div class="accordion__content rte">{{ product.description }}</div>
            </details>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </div>

  {% comment %} ---------- STICKY ADD TO CART ---------- {% endcomment %}
  <sticky-atc class="product__sticky full-width" data-target="[data-buy-buttons]" hidden>
    <div class="product__sticky-inner">
      <span class="product__sticky-title">{{ product.title }}</span>
      <span class="product__sticky-price" data-product-price>{{ current_variant.price | money }}</span>
      <button type="submit" form="{{ form_id }}" class="product__atc product__atc--compact">
        {{ 'product.add_to_cart' | t }}
      </button>
    </div>
  </sticky-atc>

  {% comment %} ---------- JSON-LD (Product + Offer) ---------- {% endcomment %}
  {% liquid
    assign og_image = product.featured_media.preview_image | default: product.featured_image
  %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ shop.url | append: product.url | json }},
      {% if og_image %}"image": [{{ og_image | image_url: width: 1200 | prepend: 'https:' | json }}],{% endif %}
      "description": {{ product.description | strip_html | truncate: 500 | json }},
      "brand": { "@type": "Brand", "name": {{ shop.name | json }} },
      {% if current_variant.sku != blank %}"sku": {{ current_variant.sku | json }},{% endif %}
      "offers": {
        "@type": "Offer",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "price": {{ current_variant.price | divided_by: 100.0 | json }},
        "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}",
        "url": {{ shop.url | append: product.url | json }}
      }
      {% comment %} No aggregateRating/review yet — add here once a reviews app is connected. {% endcomment %}
    }
  </script>

  {% comment %} ---------- JSON-LD (BreadcrumbList) ---------- {% endcomment %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ 'general.home' | t | json }},
          "item": {{ shop.url | append: routes.root_url | json }}
        }{% if bc_collection %},
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ bc_collection.title | json }},
          "item": {{ shop.url | append: bc_collection.url | json }}
        }{% endif %},
        {
          "@type": "ListItem",
          "position": {% if bc_collection %}3{% else %}2{% endif %},
          "name": {{ product.title | json }},
          "item": {{ shop.url | append: product.url | json }}
        }
      ]
    }
  </script>
</section>

{% stylesheet %}
  .product {
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 2.5rem var(--rar-page-margin) 4rem;
  }
  .product__breadcrumbs {
    margin-bottom: 1.25rem;
  }
  .product__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .product__media-main {
    position: relative;
    border-radius: var(--rar-radius-card);
    overflow: hidden;
    background-color: var(--rar-color-surface);
  }
  .product__media-slide[hidden] {
    display: none;
  }
  .product__media-slide img,
  .product__media-slide video,
  .product__media-slide iframe,
  .product__media-slide model-viewer {
    display: block;
    width: 100%;
    height: auto;
  }
  .product__thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .product__thumb {
    width: 4.5rem;
    padding: 0;
    border: 1.5px solid transparent;
    border-radius: var(--rar-radius-button);
    background: none;
    cursor: pointer;
    overflow: hidden;
  }
  .product__thumb[aria-current='true'] {
    border-color: var(--rar-accent);
  }
  .product__thumb img {
    width: 100%;
    height: auto;
    display: block;
  }

  .product__title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.75rem, 1.2rem + 2vw, 2.5rem);
  }
  .product__price {
    margin-bottom: 1.5rem;
    color: var(--rar-price);
    font-size: 1.5rem;
    font-weight: 600;
  }

  .product__option {
    margin: 0 0 1.25rem;
    padding: 0;
    border: 0;
  }
  .product__option-label {
    padding: 0;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    color: rgb(28 40 48 / 70%);
  }
  .product__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .product__swatch input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .product__swatch span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    padding: 0.55rem 1rem;
    border: 1.5px solid rgb(28 40 48 / 20%);
    border-radius: var(--rar-radius-button);
    cursor: pointer;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }
  .product__swatch input:checked + span {
    border-color: var(--rar-accent);
    background-color: var(--rar-color-surface);
  }
  .product__swatch input:focus-visible + span {
    outline: 2px solid var(--rar-accent);
    outline-offset: 2px;
  }
  .product__swatch input:disabled + span {
    opacity: 0.4;
    text-decoration: line-through;
    cursor: not-allowed;
  }

  .product__quantity {
    margin-bottom: 1.5rem;
  }
  .product__quantity-label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    color: rgb(28 40 48 / 70%);
  }
  .product__quantity-control {
    display: inline-flex;
    align-items: center;
    border: 1.5px solid rgb(28 40 48 / 20%);
    border-radius: var(--rar-radius-button);
    overflow: hidden;
  }
  .product__quantity-button {
    width: 2.75rem;
    height: 2.75rem;
    border: 0;
    background: transparent;
    color: var(--rar-text);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
  }
  .product__quantity-button:hover {
    background-color: var(--rar-color-surface);
  }
  .product__quantity-input {
    width: 3rem;
    height: 2.75rem;
    border: 0;
    border-inline: 1.5px solid rgb(28 40 48 / 16%);
    border-radius: 0;
    text-align: center;
    font: inherit;
    color: var(--rar-text);
    -moz-appearance: textfield;
  }
  .product__quantity-input::-webkit-outer-spin-button,
  .product__quantity-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .product__usp {
    margin: 1.5rem 0;
    font-size: 0.9375rem;
  }
  .product__usp ul {
    padding-left: 1.1rem;
  }
  .product__usp li {
    margin-bottom: 0.4rem;
  }
  .product__short-description {
    margin: 0 0 1.5rem;
    color: rgb(28 40 48 / 80%);
  }

  .product__highlights {
    margin: 2rem 0;
  }
  .product__highlights-title {
    margin: 0 0 1rem;
    font-size: 1.125rem;
  }

  .product__buy {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .product__atc {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 3.5rem;
    padding: 0.85rem 1.5rem;
    border: 0;
    border-radius: var(--rar-radius-button);
    background-color: var(--rar-accent);
    color: #fff;
    font: inherit;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
  }
  .product__atc:hover {
    filter: brightness(0.96);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgb(176 124 76 / 28%);
  }
  .product__atc:active {
    transform: translateY(0);
    box-shadow: none;
  }
  .product__atc:disabled {
    background-color: rgb(28 40 48 / 22%);
    box-shadow: none;
    transform: none;
    cursor: not-allowed;
  }

  /* Express checkout (Shop Pay etc.): full-width below the primary CTA. */
  .product__buy .shopify-payment-button {
    width: 100%;
  }
  .product__buy .shopify-payment-button__button {
    min-height: 3.5rem;
    border-radius: var(--rar-radius-button);
  }
  /* Tame the default "More payment options" link — subtle, centered, no ugly underline. */
  .product__buy .shopify-payment-button__more-options {
    display: block;
    margin-top: 0.6rem;
    color: rgb(28 40 48 / 55%);
    font-size: 0.8125rem;
    text-align: center;
    text-decoration: none;
  }
  .product__buy .shopify-payment-button__more-options:hover {
    color: var(--rar-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .product__trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin: 0.5rem 0 0;
    color: rgb(28 40 48 / 55%);
    font-size: 0.8125rem;
  }
  .product__trust svg {
    flex: 0 0 auto;
    color: var(--rar-eco);
  }

  .product__reassurance {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 0 0 1.5rem;
    padding: 1.25rem;
    list-style: none;
    border-radius: var(--rar-radius-card);
    background-color: var(--rar-color-surface);
  }
  .product__reassurance-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
  }
  .product__reassurance-item svg {
    flex: 0 0 auto;
    color: var(--rar-eco);
  }
  @media (max-width: 749px) {
    .product__reassurance {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }
  }

  .product__accordions {
    margin: 1rem 0;
    border-top: 1px solid rgb(28 40 48 / 10%);
  }
  .accordion {
    border-bottom: 1px solid rgb(28 40 48 / 10%);
  }
  .accordion__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    font-family: var(--rar-font-heading);
    font-size: 1.0625rem;
    cursor: pointer;
    list-style: none;
  }
  .accordion__summary::-webkit-details-marker {
    display: none;
  }
  .accordion__chevron {
    flex: 0 0 auto;
    transition: transform 0.2s ease;
  }
  .accordion[open] .accordion__chevron {
    transform: rotate(180deg);
  }
  .accordion__content {
    padding: 0 0 1.25rem;
    color: rgb(28 40 48 / 80%);
    font-size: 0.9375rem;
  }

  .product__description-wrapper {
    max-width: 800px;
    margin: 3.5rem auto 0;
    padding-top: 3rem;
    border-top: 1px solid rgb(28 40 48 / 10%);
  }
  .product__description {
    line-height: 1.7;
  }
  .product__description > :first-child {
    margin-top: 0;
  }
  /* Description images: centered, framed figures — predictable and premium
     whatever the content order. Wrappers (<p>/<div> holding only an image)
     get the surface frame; the image fills it. */
  .product__description :is(p, div):has(> img:only-child) {
    width: fit-content;
    max-width: 100%;
    margin: 1.75rem auto;
    padding: 0.75rem;
    background-color: var(--rar-color-surface);
    border-radius: var(--rar-radius-card);
  }
  .product__description :is(p, div):has(> img:only-child) img {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 0;
    border-radius: calc(var(--rar-radius-card) - 4px);
  }

  .product__sticky {
    position: fixed;
    inset-block-end: 0;
    inset-inline: 0;
    z-index: 60;
    background-color: var(--rar-color-background);
    box-shadow: 0 -4px 24px rgb(28 40 48 / 10%);
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }
  .product__sticky[data-visible] {
    transform: translateY(0);
  }
  .product__sticky-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 0.75rem var(--rar-page-margin);
  }
  .product__sticky-title {
    flex: 1 1 auto;
    font-family: var(--rar-font-heading);
    font-size: 1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .product__sticky-price {
    margin: 0;
    font-weight: 600;
  }
  .product__atc--compact {
    width: auto;
    min-height: 2.75rem;
    flex: 0 0 auto;
  }

  @media (min-width: 750px) {
    .product__layout {
      grid-template-columns: 1fr 1fr;
      gap: 3.5rem;
      align-items: start;
    }
    .product__media {
      position: sticky;
      top: 6.5rem;
    }
    /* Portrait product images barely fit a 13" laptop — cap the image height to
       the viewport (minus header) and let the frame hug it, centered. */
    .product__media-main {
      width: fit-content;
      max-width: 100%;
      margin-inline: auto;
    }
    .product__media-slide img {
      width: auto;
      max-width: 100%;
      max-height: calc(100vh - 8.5rem);
      margin-inline: auto;
    }
    .product__sticky-title {
      max-width: 50%;
    }
  }
{% endstylesheet %}

{% javascript %}
  class ProductGallery extends HTMLElement {
    connectedCallback() {
      this.slides = this.querySelectorAll('.product__media-slide');
      this.thumbs = this.querySelectorAll('.product__thumb');
      this.thumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => this.show(thumb.dataset.thumb));
      });
    }

    show(mediaId) {
      this.slides.forEach((slide) => {
        slide.hidden = slide.dataset.mediaId !== mediaId;
      });
      this.thumbs.forEach((thumb) => {
        if (thumb.dataset.thumb === mediaId) {
          thumb.setAttribute('aria-current', 'true');
        } else {
          thumb.removeAttribute('aria-current');
        }
      });
    }
  }
  if (!customElements.get('product-gallery')) {
    customElements.define('product-gallery', ProductGallery);
  }

  class QuantityInput extends HTMLElement {
    connectedCallback() {
      this.input = this.querySelector('input');
      this.querySelector('[data-quantity-minus]').addEventListener('click', () => this.step(-1));
      this.querySelector('[data-quantity-plus]').addEventListener('click', () => this.step(1));
    }

    step(delta) {
      const min = parseInt(this.input.min, 10) || 1;
      const current = parseInt(this.input.value, 10) || min;
      this.input.value = Math.max(min, current + delta);
      this.input.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }
  if (!customElements.get('quantity-input')) {
    customElements.define('quantity-input', QuantityInput);
  }

  class VariantSelector extends HTMLElement {
    connectedCallback() {
      const dataEl = this.querySelector('[data-variants]');
      this.variants = dataEl ? JSON.parse(dataEl.textContent) : {};
      this.form = this.closest('form');
      this.idInput = this.form ? this.form.querySelector('[data-variant-id]') : null;
      this.addEventListener('change', () => this.onChange());
    }

    selectedOptions() {
      return Array.from(this.querySelectorAll('input[type="radio"]:checked')).map((i) => i.value);
    }

    onChange() {
      const chosen = this.selectedOptions();
      let matchId = null;
      let match = null;
      Object.keys(this.variants).forEach((id) => {
        const v = this.variants[id];
        if (v.options.length === chosen.length && v.options.every((opt, i) => opt === chosen[i])) {
          matchId = id;
          match = v;
        }
      });
      if (!matchId || !match) return;

      if (this.idInput) this.idInput.value = matchId;

      document.querySelectorAll('[data-product-price]').forEach((el) => {
        el.innerHTML = match.price;
      });

      const addButton = this.form ? this.form.querySelector('.product__atc') : null;
      const label = addButton ? addButton.querySelector('[data-add-label]') : null;
      if (addButton) {
        addButton.disabled = !match.available;
        if (label) {
          label.textContent = match.available
            ? addButton.dataset.labelAvailable
            : addButton.dataset.labelSoldout;
        }
      }

      const url = this.dataset.url;
      if (url && window.history && window.history.replaceState) {
        window.history.replaceState({}, '', url + '?variant=' + matchId);
      }
    }
  }
  if (!customElements.get('variant-selector')) {
    customElements.define('variant-selector', VariantSelector);
  }

  class StickyAtc extends HTMLElement {
    connectedCallback() {
      const target = document.querySelector(this.dataset.target);
      if (!target || !('IntersectionObserver' in window)) return;
      this.hidden = false;
      this.observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting || entry.boundingClientRect.top > 0) {
              this.removeAttribute('data-visible');
            } else {
              this.setAttribute('data-visible', '');
            }
          });
        },
        { rootMargin: '0px 0px 0px 0px' }
      );
      this.observer.observe(target);
    }

    disconnectedCallback() {
      if (this.observer) this.observer.disconnect();
    }
  }
  if (!customElements.get('sticky-atc')) {
    customElements.define('sticky-atc', StickyAtc);
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_reassurance",
      "label": "t:labels.show_reassurance",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_long_description",
      "label": "Show full description (in an accordion)",
      "info": "Adds the product's full description as a collapsed accordion row. Kept for SEO; the body text stays on the page.",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "size_helper",
      "name": "t:general.size_helper",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:info.size_helper"
        },
        {
          "type": "range",
          "id": "margin",
          "label": "t:labels.size_margin",
          "min": 0,
          "max": 30,
          "step": 1,
          "unit": "mm",
          "default": 6
        }
      ]
    },
    {
      "type": "collapsible",
      "name": "t:general.collapsible_row",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:labels.text"
        },
        {
          "type": "header",
          "content": "t:labels.metafield_override"
        },
        {
          "type": "text",
          "id": "metafield_namespace",
          "label": "t:labels.metafield_namespace"
        },
        {
          "type": "text",
          "id": "metafield_key",
          "label": "t:labels.metafield_key"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
