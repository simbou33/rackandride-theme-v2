{% comment %}
  Homepage hero. Full-bleed image (or solid surface when no image is set — no
  Dawn placeholder), with a headline, subtext and up to two CTAs. Overlay and
  height are configurable. The headline is the page H1 on the homepage.
{% endcomment %}

<section
  class="hero full-width hero--{{ section.settings.height }} hero--align-{{ section.settings.text_alignment }}"
  style="--hero-overlay: {{ section.settings.overlay_opacity }}%;"
>
  <div class="hero__media">
    {% if section.settings.image %}
      {{
        section.settings.image
        | image_url: width: 3000
        | image_tag:
          widths: '750, 1100, 1500, 2000, 3000',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.heading | default: shop.name
      }}
    {% else %}
      <img
        src="{{ 'hero-rackandride.webp' | asset_url }}"
        alt="{{ section.settings.heading | default: shop.name | escape }}"
        width="2048"
        height="1365"
        loading="eager"
        fetchpriority="high"
      >
    {% endif %}
  </div>

  <div class="hero__content">
    {% if section.settings.heading != blank %}
      <h1 class="hero__title">{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <div class="hero__subtitle">{{ section.settings.subheading }}</div>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <div class="hero__buttons">
        <a class="hero__button hero__button--primary" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label }}
        </a>
        {% if section.settings.button_2_label != blank and section.settings.button_2_link != blank %}
          <a class="hero__button hero__button--ghost" href="{{ section.settings.button_2_link }}">
            {{ section.settings.button_2_label }}
          </a>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.proof_text != blank %}
      <p class="hero__proof">
        <span class="hero__stars" aria-hidden="true">
          <span class="hero__stars-bg">{% for i in (1..5) %}<svg viewBox="0 0 20 20" width="16" height="16" focusable="false"><path d="M10 2l2.4 4.9 5.4.8-3.9 3.8.9 5.4-4.8-2.5-4.8 2.5.9-5.4L2.2 7.7l5.4-.8z"/></svg>{% endfor %}</span>
          <span class="hero__stars-fg">{% for i in (1..5) %}<svg viewBox="0 0 20 20" width="16" height="16" focusable="false"><path d="M10 2l2.4 4.9 5.4.8-3.9 3.8.9 5.4-4.8-2.5-4.8 2.5.9-5.4L2.2 7.7l5.4-.8z"/></svg>{% endfor %}</span>
        </span>
        {{ section.settings.proof_text }}
      </p>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .hero {
    position: relative;
    display: grid;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }
  .hero--small {
    min-height: 52vh;
  }
  .hero--medium {
    min-height: 68vh;
  }
  .hero--large {
    min-height: 86vh;
  }
  .hero--plain {
    background-color: var(--rar-color-surface);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero:not(.hero--plain) .hero__media::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(to top, rgb(28 40 48 / 45%), transparent 55%),
      linear-gradient(to right, rgb(28 40 48 / 35%), transparent 65%),
      rgb(28 40 48 / var(--hero-overlay));
  }

  .hero__content {
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 3rem var(--rar-page-margin);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: min(var(--rar-page-width), 100%);
  }
  .hero:not(.hero--plain) .hero__content {
    color: #fff;
  }
  .hero__content > * {
    max-width: 36rem;
  }
  .hero--align-center .hero__content {
    align-items: center;
    text-align: center;
  }
  .hero--align-center .hero__content > * {
    margin-inline: auto;
  }

  .hero__kicker {
    margin: 0 0 0.6rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .hero__title {
    margin: 0;
    font-size: clamp(2.25rem, 1.5rem + 3.5vw, 4rem);
    line-height: 1.05;
  }
  .hero:not(.hero--plain) .hero__title {
    color: #fff;
  }
  .hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.6;
  }

  .hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .hero__proof {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0.5rem 0 0;
    font-size: 0.9375rem;
  }
  .hero__stars {
    position: relative;
    display: inline-flex;
    line-height: 0;
  }
  .hero__stars-bg {
    display: inline-flex;
    gap: 0.1rem;
    opacity: 0.35;
  }
  .hero__stars-fg {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    display: inline-flex;
    gap: 0.1rem;
    width: 90%;
    overflow: hidden;
    white-space: nowrap;
  }
  .hero__stars svg {
    fill: currentColor;
    flex: 0 0 auto;
  }
  .hero--align-center .hero__proof {
    justify-content: center;
  }
  .hero__button {
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--rar-radius-button);
    font-weight: 600;
    text-decoration: none;
  }
  .hero__button--primary {
    background-color: var(--rar-accent);
    color: #fff;
  }
  .hero__button--primary:hover {
    filter: brightness(0.94);
  }
  .hero__button--ghost {
    border: 1.5px solid currentColor;
    color: inherit;
  }
  .hero--plain .hero__button--ghost {
    color: var(--rar-accent);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Display your boards like art"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "<p>Handmade wall mounts in solid oak — crafted in Gironde, France.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Shop all"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:labels.button_link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "t:labels.button_2_label"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "t:labels.button_2_link"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:labels.height",
      "default": "medium",
      "options": [
        { "value": "small", "label": "t:options.size.small" },
        { "value": "medium", "label": "t:options.size.medium" },
        { "value": "large", "label": "t:options.size.large" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:labels.alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" }
      ]
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:labels.overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "text",
      "id": "proof_text",
      "label": "t:labels.proof_text",
      "default": "Rated 4.5/5 — 121 reviews on Etsy"
    }
  ],
  "presets": [{ "name": "t:general.hero" }],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
