{% comment %}
  Reusable storytelling section: a stack of image + text rows that alternate
  left/right on desktop. Built for the product page (SEO-rich storytelling) and
  the homepage (brand story). Graceful by design:
  - row with an image → two columns, alternating sides
  - row without an image → centered single-column text
  - no rows / empty → renders nothing (no placeholders)
{% endcomment %}

{% liquid
  # On a product page, prefer per-product story blocks from the `custom.story`
  # metaobject list; otherwise fall back to this section's own blocks (homepage).
  assign meta_story = blank
  if product != blank
    assign meta_story = product.metafields.custom.story.value
  endif
  assign use_meta = false
  if meta_story != blank and meta_story.size > 0
    assign use_meta = true
  endif

  assign has_rows = false
  for block in section.blocks
    if block.type == 'row'
      assign has_rows = true
      break
    endif
  endfor
%}

{% if use_meta or has_rows or section.settings.heading != blank %}
  <section class="story-rows">
    {% if section.settings.heading != blank %}
      <div class="story-rows__header">
        <h2 class="story-rows__title">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="story-rows__list">
      {% if use_meta %}
        {% for entry in meta_story %}
          {% liquid
            assign s_image = entry.image.value
            assign s_reverse = ''
            assign s_mod = forloop.index0 | modulo: 2
            if s_mod == 1
              assign s_reverse = ' story-row--image-right'
            endif
          %}
          <div class="story-row{% unless s_image %} story-row--text-only{% endunless %}{{ s_reverse }}">
            {% if s_image %}
              <div class="story-row__media">
                {{
                  s_image
                  | image_url: width: 1000
                  | image_tag:
                    widths: '400, 600, 800, 1000',
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    loading: 'lazy',
                    alt: entry.image_alt.value | default: entry.heading.value
                }}
              </div>
            {% endif %}
            <div class="story-row__content">
              {% if entry.heading.value != blank %}
                <h3 class="story-row__heading">{{ entry.heading.value }}</h3>
              {% endif %}
              {% if entry.text.value != blank %}
                <div class="story-row__text rte">{{ entry.text.value | newline_to_br }}</div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for block in section.blocks %}
        {% if block.type == 'row' %}
          {% liquid
            assign has_image = false
            if block.settings.image or block.settings.image_asset != blank
              assign has_image = true
            endif
          %}
          <div
            class="story-row{% unless has_image %} story-row--text-only{% endunless %}{% if block.settings.image_position == 'right' %} story-row--image-right{% endif %}"
            {{ block.shopify_attributes }}
          >
            {% if has_image %}
              <div class="story-row__media">
                {% if block.settings.image %}
                  {{
                    block.settings.image
                    | image_url: width: 1000
                    | image_tag:
                      widths: '400, 600, 800, 1000',
                      sizes: '(min-width: 750px) 50vw, 100vw',
                      loading: 'lazy',
                      alt: block.settings.image.alt | default: block.settings.heading
                  }}
                {% else %}
                  <img
                    src="{{ block.settings.image_asset | asset_url }}"
                    alt="{{ block.settings.heading | escape }}"
                    width="900"
                    height="1125"
                    loading="lazy"
                  >
                {% endif %}
              </div>
            {% endif %}

            <div class="story-row__content">
              {% if block.settings.heading != blank %}
                <h3 class="story-row__heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class="story-row__text rte">{{ block.settings.text }}</div>
              {% endif %}
              {% if block.settings.button_label != blank and block.settings.button_link != blank %}
                <a class="story-row__button" href="{{ block.settings.button_link }}">
                  {{ block.settings.button_label }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .story-rows {
    width: 100%;
    max-width: var(--rar-page-width);
    margin-inline: auto;
    padding: 4rem var(--rar-page-margin);
  }
  .story-rows__header {
    margin-bottom: 3rem;
    text-align: center;
  }
  .story-rows__title {
    margin: 0;
    font-size: clamp(1.75rem, 1.2rem + 2vw, 2.5rem);
  }
  .story-rows__list {
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
  }
  /* Rows that have an image get more breathing room than text-only rows */
  .story-row:not(.story-row--text-only) {
    margin-block: 1.25rem;
  }

  .story-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
  }
  .story-row--text-only {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }

  .story-row__media {
    border-radius: var(--rar-radius-card);
    overflow: hidden;
    background-color: var(--rar-color-surface);
  }
  .story-row__media img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .story-row__heading {
    margin: 0 0 1rem;
    font-size: clamp(1.4rem, 1rem + 1.4vw, 2rem);
  }
  .story-row__text {
    color: rgb(28 40 48 / 80%);
    line-height: 1.7;
  }
  .story-row__button {
    display: inline-flex;
    align-items: center;
    margin-top: 1.5rem;
    padding: 0.7rem 1.5rem;
    border: 1.5px solid var(--rar-accent);
    border-radius: var(--rar-radius-button);
    color: var(--rar-accent);
    font-weight: 600;
    text-decoration: none;
  }
  .story-row__button:hover {
    background-color: var(--rar-accent);
    color: #fff;
  }

  @media (min-width: 750px) {
    .story-row:not(.story-row--text-only) {
      grid-template-columns: 1fr 1fr;
      gap: 3.5rem;
    }
    /* Image side is controlled per row (no auto-alternation) */
    .story-row--image-right .story-row__media {
      order: 2;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.story_rows",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "t:general.story_row",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "t:labels.image_asset",
          "info": "t:info.image_asset"
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "t:labels.image_position",
          "default": "left",
          "options": [
            { "value": "left", "label": "t:options.alignment.left" },
            { "value": "right", "label": "t:options.alignment.right" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:labels.text"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:labels.button_label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:labels.button_link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.story_rows",
      "blocks": [{ "type": "row" }, { "type": "row" }, { "type": "row" }]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
